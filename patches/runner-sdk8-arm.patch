+
+        [Theory]
+        [Trait("Level", "L0")]
+        [Trait("Category", "Worker")]
+        [InlineData(true, "node20", true)]
+        [InlineData(true, "node22", false)]
+        [InlineData(true, "node24", false)]
+        [InlineData(false, "node20", false)]
+        public void ShouldTrackAsDeprecatedNode20_OnlyTracksNode20(
+            bool warnOnNode20,
+            string finalNodeVersion,
+            bool expected)
+        {
+            // On Linux ARM32, node24-targeted actions resolve to node22 (not node20).
+            // The deprecated-node20 annotation must only apply to actions actually
+            // running on node20, otherwise node22-executed actions are mislabeled.
+            bool actual = HandlerFactory.ShouldTrackAsDeprecatedNode20(
+                warnOnNode20,
+                finalNodeVersion);
+
+            Assert.Equal(expected, actual);
+        }
